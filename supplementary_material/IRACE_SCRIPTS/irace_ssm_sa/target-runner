#!/bin/bash
# irace target-runner for Split-Solve-Merge Simulated Annealing (SSM-SA)
#
# irace calls: target-runner <candidate_id> <instance_id> <seed> <instance> [params...]
# This script forwards to the Julia runner via the DaemonMode client.
#
# Usage with daemon (recommended — eliminates ~30s Julia startup per call):
#   Terminal A (start once, keep alive):
#     julia --startup-file=no --project=/home/nuno/DrWatsonProjects/SoftIdea \
#           -t auto -e 'using DaemonMode; serve()'
#   Terminal B (run irace):
#     cd /home/nuno/DrWatsonProjects/SoftIdea/irace_ssm_sa
#     Rscript -e "library(irace); irace.cmdline()"
#
# Usage without daemon (slower, ~30s Julia startup per call):
#   Set USE_DAEMON=0 below.
#
# NOTE: Each SSM-SA evaluation takes 15–1850 s depending on instance.
#       The DaemonMode startup savings are small relative to run time.

# Allow overriding via environment (e.g. export USE_DAEMON=0 for smoke tests)
USE_DAEMON=${USE_DAEMON:-1}

PROJECT="/home/nuno/DrWatsonProjects/SoftIdea"
RUNNER="${PROJECT}/scripts/irace_ssm_sa_runner.jl"

# irace positional arguments
CANDIDATE_ID="$1"
INSTANCE_ID="$2"
SEED="$3"
INSTANCE="$4"
shift 4
# Remaining args are parameter name-value pairs: --T0 5.0 --Tf 0.01 --Nit 100

if [[ "$USE_DAEMON" -eq 1 ]]; then
    julia --startup-file=no --project="$PROJECT" \
          -e 'using DaemonMode; runargs()' \
          "$RUNNER" "$INSTANCE" "$SEED" "$CANDIDATE_ID" "$@"
else
    julia --startup-file=no --project="$PROJECT" \
          "$RUNNER" "$INSTANCE" "$SEED" "$CANDIDATE_ID" "$@"
fi
